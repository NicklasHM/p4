using RAL.AST;
using System.Globalization;


using System;



public class Parser {
	public const int _EOF = 0;
	public const int _ident = 1;
	public const int _number = 2;
	public const int _stringLit = 3;
	public const int _dateLit = 4;
	public const int _timeLit = 5;
	public const int maxT = 71;

	const bool _T = true;
	const bool _x = false;
	const int minErrDist = 2;
	
	public Scanner scanner;
	public Errors  errors;

	public Token t;    // last recognized token
	public Token la;   // lookahead token
	int errDist = minErrDist;

public Stmt mainNode = null; // This contains the AST generated by calling parser.Parse().


/// Convert a list of statements into a single nested "composite" AST node.
Stmt toComposite(List<Stmt> stmts) {
  // If "stmts" is empty, return Skip to represent no statements/body.
  if (stmts.Count == 0)
    return new Skip(-1);

  // Start with the last statement as the initial result.
  // This becomes the deepest node in the nested Composite structure.
  Stmt result = stmts[stmts.Count - 1];

  // Start folding from the second-to-last statement.
  // Lists are zero-indexed, so Count - 2 gives the index before the last item.
  int index = stmts.Count - 2;

  // Walk backwards through the list so the original execution order is preserved.
  while (index >= 0) {
    // Get the current statement that will be nested to the left of the result.
    Stmt current = stmts[index];

    // If the current statement is already a Composite, preserve its left child.
    if (current is Composite comp)
      // Nest the Composite's right child together with the accumulated result.
      // This avoids losing the original left/right structure of the Composite.
      result = new Composite(
        comp.LineNumber,
        comp.Stmt1,
        new Composite(comp.LineNumber, comp.Stmt2, result)
      );
    else
      // Normal case: create a Composite where the current statement is on the left
      // and the accumulated result is on the right.
      // Use current.LineNumber so diagnostics still point to the source statement.
      result = new Composite(current.LineNumber, current, result);

    // Move to the previous statement in the list.
    index--;
  }

  // Return the fully nested Composite AST node.
  return result;
}

/* ___________________LL(1) Conflict Resolvers_____________________*/
/* For ident in VarDecl and Primary Exp*/
bool FollowedByIdent() {
    scanner.ResetPeek();
    Token next = scanner.Peek();
    return la.kind == _ident && next.kind == _ident;
}

/* For number in Primary Exp and Duration */
bool FollowedByUnit() {
    scanner.ResetPeek();
    Token next = scanner.Peek();
    return la.kind == _number &&
           (next.val == "w" || next.val == "week" || next.val == "weeks" ||
           next.val == "d" || next.val == "day"  || next.val == "days"  ||
           next.val == "h" || next.val == "hour" || next.val == "hours" ||
           next.val == "m" || next.val == "minute" || next.val == "minutes");
}

/* For number in alternatives of Duration */
bool FollowedByWeek() {
    scanner.ResetPeek();
    Token next = scanner.Peek();
    return next.val == "w" || next.val == "week" || next.val == "weeks";
}

bool FollowedByDay(){
    scanner.ResetPeek();
    Token next = scanner.Peek();
    return next.val == "d" || next.val == "day"  || next.val == "days";
}

bool FollowedByHour() {
    scanner.ResetPeek();
    Token next = scanner.Peek();
    return next.val == "h" || next.val == "hour" || next.val == "hours";
}

// Resolver between alternatives within ResourceExp: r | a*id *id
bool FollowedByAND_or_FROM() {
    scanner.ResetPeek();
    Token next = scanner.Peek();
    return la.kind == _ident && (next.val == "and" || next.val == "from");
}



	public Parser(Scanner scanner) {
		this.scanner = scanner;
		errors = new Errors();
	}

	void SynErr (int n) {
		if (errDist >= minErrDist) errors.SynErr(la.line, la.col, n);
		errDist = 0;
	}

	public void SemErr (string msg) {
		if (errDist >= minErrDist) errors.SemErr(t.line, t.col, msg);
		errDist = 0;
	}
	
	void Get () {
		for (;;) {
			t = la;
			la = scanner.Scan();
			if (la.kind <= maxT) { ++errDist; break; }

			la = t;
		}
	}
	
	void Expect (int n) {
		if (la.kind==n) Get(); else { SynErr(n); }
	}
	
	bool StartOf (int s) {
		return set[s, la.kind];
	}
	
	void ExpectWeak (int n, int follow) {
		if (la.kind == n) Get();
		else {
			SynErr(n);
			while (!StartOf(follow)) Get();
		}
	}


	bool WeakSeparator(int n, int syFol, int repFol) {
		int kind = la.kind;
		if (kind == n) {Get(); return true;}
		else if (StartOf(repFol)) {return false;}
		else {
			SynErr(n);
			while (!(set[syFol, kind] || set[repFol, kind] || set[0, kind])) {
				Get();
				kind = la.kind;
			}
			return StartOf(syFol);
		}
	}

	
	void RAL() {
		TopLevelStmts(out mainNode);
		Expect(0);
	}

	void TopLevelStmts(out Stmt stmt) {
		List<Stmt> list = new List<Stmt>(); 
		while (StartOf(1)) {
			TopLevelStmt(out Stmt temporary);
			list.Add(temporary); 
		}
		stmt = toComposite(list); 
	}

	void TopLevelStmt(out Stmt stmt) {
		stmt = new Skip(t.line); 
		if (la.kind == 7 || la.kind == 25) {
			if (la.kind == 25) {
				CategoryDecl(out stmt);
			} else {
				Move(out stmt);
			}
			Expect(6);
		} else if (la.kind == 28) {
			TemplateDecl(out stmt);
		} else if (FollowedByIdent()) {
			ResourceDecl(out stmt);
		} else if (StartOf(2)) {
			Stmt(out stmt);
		} else SynErr(72);
	}

	void CategoryDecl(out Stmt stmt) {
		Expect(25);
		int lineNumber = t.line; 
		Expect(1);
		string categoryId = t.val; string? parentId = null; 
		if (la.kind == 26) {
			Get();
			Expect(27);
			Expect(1);
			parentId = t.val; 
		}
		stmt = new CategoryDecl (lineNumber, categoryId, parentId);  
	}

	void Move(out Stmt stmt) {
		Expect(7);
		int lineNumber = t.line; 
		Expect(1);
		string resourceId = t.val; 
		Expect(8);
		Expect(1);
		stmt = new Move(lineNumber, resourceId, new ResourceT(t.val)); 
	}

	void TemplateDecl(out Stmt stmt) {
		Expect(28);
		int lineNumber = t.line; List<VarDecl> paramList = new(); 
		Expect(1);
		string templateId = t.val; 
		Expect(11);
		if (StartOf(3)) {
			Param(out VarDecl param);
			paramList.Add(param);
			while (la.kind == 29) {
				Get();
				Param(out VarDecl nextParam);
				paramList.Add(nextParam); 
			}
		}
		Expect(12);
		Expect(14);
		Stmts(out Stmt body);
		Expect(15);
		stmt = new TemplateDecl(lineNumber, templateId, paramList, body); 
	}

	void ResourceDecl(out Stmt stmt) {
		Expect(1);
		int lineNumber = t.line; ResourceT type = new ResourceT(t.val); 
		Expect(1);
		string identifier = t.val; List<Stmt>? propertyList = null; 
		Expect(14);
		if (StartOf(4)) {
			propertyList = new List<Stmt>(); 
			VarDecl(out Stmt prop);
			Expect(6);
			propertyList.Add(prop); 
			while (StartOf(4)) {
				VarDecl(out Stmt nextProp);
				Expect(6);
				propertyList.Add(nextProp); 
			}
		}
		Expect(15);
		stmt = new ResourceDecl(lineNumber, type, identifier, propertyList); 
	}

	void Stmt(out Stmt stmt) {
		stmt = new Skip(t.line); 
		if (StartOf(5)) {
			if (StartOf(4)) {
				VarDecl(out stmt);
			} else if (la.kind == 9) {
				Cancel(out stmt);
			} else if (StartOf(6)) {
				Exp(out Exp exp);
				stmt = new ExpStmt(exp.LineNumber, exp); 
			} else if (la.kind == 49) {
				Availability(out stmt);
			} else {
				TemplateCall(out stmt);
			}
			Expect(6);
		} else if (la.kind == 10) {
			If(out stmt);
		} else SynErr(73);
	}

	void Stmts(out Stmt stmt) {
		List<Stmt> list = new List<Stmt>(); 
		while (StartOf(2)) {
			Stmt(out Stmt temporary);
			list.Add(temporary); 
		}
		stmt = toComposite(list); 
	}

	void VarDecl(out Stmt stmt) {
		Type(out TypeT type);
		int lineNumber = t.line; 
		Expect(1);
		string identifier = t.val; stmt = new VarDecl(lineNumber, type, identifier); 
		if (la.kind == 17) {
			Get();
			Exp(out Exp exp);
			stmt = new Composite(lineNumber, stmt, new ExpStmt(lineNumber, new Assignment(lineNumber, new Reference(lineNumber, identifier, null), exp))); 
		}
	}

	void Cancel(out Stmt stmt) {
		Expect(9);
		int lineNumber = t.line;
		Exp(out Exp reservation);
		stmt = new Cancel(lineNumber, reservation); 
	}

	void Exp(out Exp exp) {
		LogicalOrExp(out exp);
	}

	void Availability(out Stmt stmt) {
		Expect(49);
		int lineNumber = t.line;
		QueryExp(out QueryData query);
		stmt = new Availability(lineNumber, query); 
	}

	void TemplateCall(out Stmt stmt) {
		Expect(47);
		int lineNumber = t.line; 
		Expect(1);
		string templateId = t.val; List<Exp> argList = new(); 
		Expect(11);
		if (StartOf(6)) {
			Exp(out Exp arg);
			argList.Add(arg);
			while (la.kind == 29) {
				Get();
				Exp(out Exp nextArg);
				argList.Add(nextArg);
			}
		}
		Expect(12);
		stmt = new TemplateCall(lineNumber, templateId, argList); 
	}

	void If(out Stmt stmt) {
		Expect(10);
		Expect(11);
		Exp(out Exp condition);
		Expect(12);
		int lineNumber = t.line; 
		Expect(13);
		Expect(14);
		Stmts(out Stmt stmtThen);
		Expect(15);
		Stmt stmtElse = new Skip(lineNumber); 
		if (la.kind == 16) {
			Get();
			Expect(14);
			Stmts(out stmtElse);
			Expect(15);
		}
		stmt = new If(lineNumber, condition, stmtThen, stmtElse); 
	}

	void Type(out TypeT type) {
		type = null; 
		switch (la.kind) {
		case 18: {
			Get();
			type = new NumberT(); 
			break;
		}
		case 19: {
			Get();
			type = new BoolT(); 
			break;
		}
		case 20: {
			Get();
			type = new StringT(); 
			break;
		}
		case 21: {
			Get();
			type = new CategoryT(); 
			break;
		}
		case 22: {
			Get();
			type = new ReservationT(); 
			break;
		}
		case 23: {
			Get();
			type = new DateTimeT(); 
			break;
		}
		case 24: {
			Get();
			type = new DurationT(); 
			break;
		}
		default: SynErr(74); break;
		}
	}

	void ParamType(out TypeT type) {
		type = null; 
		if (StartOf(4)) {
			Type(out type);
		} else if (la.kind == 1) {
			Get();
			type = new ResourceT(t.val); 
		} else SynErr(75);
	}

	void Param(out VarDecl param) {
		ParamType(out TypeT type);
		int lineNumber = t.line;
		Expect(1);
		string identifier = t.val; param = new VarDecl(lineNumber, type, identifier);
	}

	void LogicalOrExp(out Exp exp) {
		LogicalAndExp(out exp );
		while (la.kind == 30) {
			Get();
			int lineNumber = t.line; 
			LogicalAndExp(out Exp exp2);
			exp = new BinaryOperation(lineNumber, exp, BinaryOperator.OR, exp2); 
		}
	}

	void LogicalAndExp(out Exp exp) {
		SequentialExp(out exp);
		while (la.kind == 31) {
			Get();
			int lineNumber = t.line; 
			SequentialExp(out Exp exp2);
			exp = new BinaryOperation(lineNumber, exp, BinaryOperator.AND, exp2); 
		}
	}

	void SequentialExp(out Exp exp) {
		EqualityExp(out exp);
		while (la.kind == 32) {
			Get();
			int lineNumber = t.line; 
			EqualityExp(out Exp exp2);
			exp = new BinaryOperation(lineNumber, exp, BinaryOperator.SEQ, exp2); 
		}
	}

	void EqualityExp(out Exp exp) {
		BinaryOperator op; int lineNumber; 
		RelationalExp(out exp);
		while (la.kind == 33 || la.kind == 34) {
			if (la.kind == 33) {
				Get();
				op = BinaryOperator.EQ; lineNumber = t.line; 
			} else {
				Get();
				op = BinaryOperator.NEQ; lineNumber = t.line; 
			}
			RelationalExp(out Exp exp2);
			exp = new BinaryOperation(lineNumber, exp, op, exp2);
		}
	}

	void RelationalExp(out Exp exp) {
		BinaryOperator op; int lineNumber; 
		AdditiveExp(out exp);
		while (StartOf(7)) {
			if (la.kind == 35) {
				Get();
				op = BinaryOperator.LT; lineNumber = t.line; 
			} else if (la.kind == 36) {
				Get();
				op = BinaryOperator.GT; lineNumber = t.line; 
			} else if (la.kind == 37) {
				Get();
				op = BinaryOperator.LTEQ; lineNumber = t.line; 
			} else {
				Get();
				op = BinaryOperator.GTEQ; lineNumber = t.line; 
			}
			AdditiveExp(out Exp exp2);
			exp = new BinaryOperation(lineNumber, exp, op, exp2);
		}
	}

	void AdditiveExp(out Exp exp) {
		BinaryOperator op; int lineNumber; 
		MultiplicativeExp(out exp);
		while (la.kind == 39 || la.kind == 40) {
			if (la.kind == 39) {
				Get();
				op = BinaryOperator.ADD; lineNumber = t.line; 
			} else {
				Get();
				op = BinaryOperator.SUB; lineNumber = t.line; 
			}
			MultiplicativeExp(out Exp exp2);
			exp = new BinaryOperation(lineNumber, exp, op, exp2);
		}
	}

	void MultiplicativeExp(out Exp exp) {
		BinaryOperator op; int lineNumber; 
		UnaryExp(out exp);
		while (la.kind == 41 || la.kind == 42) {
			if (la.kind == 41) {
				Get();
				op = BinaryOperator.MUL; lineNumber = t.line; 
			} else {
				Get();
				op = BinaryOperator.DIV; lineNumber = t.line; 
			}
			UnaryExp(out Exp exp2);
			exp = new BinaryOperation(lineNumber, exp, op, exp2);
		}
	}

	void UnaryExp(out Exp exp) {
		exp = null; 
		if (la.kind == 40 || la.kind == 43) {
			UnaryOperator op; int lineNumber;
			if (la.kind == 43) {
				Get();
				lineNumber = t.line; op = UnaryOperator.NOT; 
			} else {
				Get();
				lineNumber = t.line; op = UnaryOperator.NEG; 
			}
			UnaryExp(out Exp innerExp);
			exp = new UnaryOperation(lineNumber, op, innerExp); 
		} else if (StartOf(8)) {
			Primary(out exp);
		} else SynErr(76);
	}

	void Primary(out Exp exp) {
		exp = null; int lineNumber = t.line; 
		if (la.kind == 1) {
			ReferenceOrAssignment(out exp);
		} else if (FollowedByUnit()) {
			Duration(out exp);
		} else if (la.kind == 2) {
			Get();
			exp = new NumberV(t.line, float.Parse(t.val)); 
		} else if (la.kind == 3) {
			Get();
			exp = new StringV(t.line, t.val);  
		} else if (la.kind == 44) {
			Get();
			exp = new BoolV(t.line, true);  
		} else if (la.kind == 45) {
			Get();
			exp = new BoolV(t.line, false);  
		} else if (la.kind == 11) {
			Get();
			Exp(out exp);
			Expect(12);
		} else if (la.kind == 4) {
			Datetime(out exp);
		} else if (la.kind == 50) {
			ReservationAtomExp(out exp);
		} else if (la.kind == 46) {
			Get();
			Exp(out Exp reservation);
			Time(out TimeSpec timeInterval);
			exp = new Reschedule(t.line, reservation, timeInterval); 
		} else SynErr(77);
	}

	void ReferenceOrAssignment(out Exp exp) {
		Expect(1);
		int lineNumber = t.line; string variableId = t.val; string? propertyId = null; exp = new Reference(lineNumber, variableId, propertyId);
		if (la.kind == 48) {
			Get();
			Expect(1);
			propertyId = t.val; exp = new Reference(lineNumber, variableId, propertyId); 
		}
		if (la.kind == 17) {
			Get();
			Exp(out exp);
			exp = new Assignment(lineNumber, new Reference(lineNumber, variableId, propertyId), exp); 
		}
	}

	void Duration(out Exp exp) {
		exp = null; int days = 0, hours = 0, minutes = 0; 
		if (FollowedByWeek()) {
			Expect(2);
			days = int.Parse(t.val) * 7; 
			if (la.kind == 54) {
				Get();
			} else if (la.kind == 55) {
				Get();
			} else if (la.kind == 56) {
				Get();
			} else SynErr(78);
			if (FollowedByDay()) {
				Expect(2);
				days += int.Parse(t.val); 
				if (la.kind == 57) {
					Get();
				} else if (la.kind == 58) {
					Get();
				} else if (la.kind == 59) {
					Get();
				} else SynErr(79);
			}
			if (FollowedByHour()) {
				Expect(2);
				hours = int.Parse(t.val); 
				if (la.kind == 60) {
					Get();
				} else if (la.kind == 61) {
					Get();
				} else if (la.kind == 62) {
					Get();
				} else SynErr(80);
			}
			if (la.kind == 2) {
				Get();
				minutes = int.Parse(t.val); 
				if (la.kind == 63) {
					Get();
				} else if (la.kind == 64) {
					Get();
				} else if (la.kind == 65) {
					Get();
				} else SynErr(81);
			}
		} else if (FollowedByDay()) {
			Expect(2);
			days = int.Parse(t.val); 
			if (la.kind == 57) {
				Get();
			} else if (la.kind == 58) {
				Get();
			} else if (la.kind == 59) {
				Get();
			} else SynErr(82);
			if (FollowedByHour()) {
				Expect(2);
				hours = int.Parse(t.val); 
				if (la.kind == 60) {
					Get();
				} else if (la.kind == 61) {
					Get();
				} else if (la.kind == 62) {
					Get();
				} else SynErr(83);
			}
			if (la.kind == 2) {
				Get();
				minutes = int.Parse(t.val); 
				if (la.kind == 63) {
					Get();
				} else if (la.kind == 64) {
					Get();
				} else if (la.kind == 65) {
					Get();
				} else SynErr(84);
			}
		} else if (FollowedByHour()) {
			Expect(2);
			hours = int.Parse(t.val); 
			if (la.kind == 60) {
				Get();
			} else if (la.kind == 61) {
				Get();
			} else if (la.kind == 62) {
				Get();
			} else SynErr(85);
			if (la.kind == 2) {
				Get();
				minutes = int.Parse(t.val); 
				if (la.kind == 63) {
					Get();
				} else if (la.kind == 64) {
					Get();
				} else if (la.kind == 65) {
					Get();
				} else SynErr(86);
			}
		} else if (la.kind == 2) {
			Get();
			minutes = int.Parse(t.val); 
			if (la.kind == 63) {
				Get();
			} else if (la.kind == 64) {
				Get();
			} else if (la.kind == 65) {
				Get();
			} else SynErr(87);
		} else SynErr(88);
		exp = new DurationV(t.line, new TimeSpan(days, hours, minutes, 0)); 
	}

	void Datetime(out Exp exp) {
		string dateTimeToParse = null; 
		Expect(4);
		dateTimeToParse = t.val; 
		if (la.kind == 5) {
			Get();
			dateTimeToParse += " " + t.val; 
		}
		exp = new DateTimeV(t.line, DateTime.Parse(dateTimeToParse, new CultureInfo("fr-FR"))); 
	}

	void ReservationAtomExp(out Exp exp) {
		Expect(50);
		int lineNumber = t.line;
		QueryExp(out QueryData query);
		exp = new Reserve(lineNumber, query); 
	}

	void Time(out TimeSpec timeInterval) {
		Exp? endMarker = null;  
		Expect(52);
		Exp(out Exp startDateTime);
		if (la.kind == 8) {
			Get();
			AdditiveExp(out Exp toDatetime);
			endMarker = toDatetime; 
		} else if (la.kind == 53) {
			Get();
			AdditiveExp(out Exp forDuration);
			endMarker = forDuration; 
		} else SynErr(89);
		timeInterval = new TimeSpec(startDateTime, endMarker); 
	}

	void QueryExp(out QueryData query) {
		Exp? condition = null; RecurrenceSpec? recurrence = null; 
		ResourceExp(out List<ResourceSpec> resources );
		Time(out TimeSpec timeInterval);
		if (la.kind == 51) {
			Get();
			Expect(11);
			Exp(out condition);
			Expect(12);
		}
		if (la.kind == 66) {
			Recurrence(out recurrence);
		}
		query = new QueryData(resources, timeInterval, condition, recurrence); 
	}

	void ResourceExp(out List<ResourceSpec> resources ) {
		resources = new List<ResourceSpec>(); Exp? quantity = null; string? categoryId = null; string? identifier = null; 
		if (FollowedByAND_or_FROM()) {
			Expect(1);
			identifier = t.val; 
		} else if (StartOf(6)) {
			AdditiveExp(out Exp exp);
			quantity = exp; 
			Expect(1);
			categoryId = t.val; 
			if (la.kind == 1) {
				Get();
				identifier = t.val; 
			}
		} else SynErr(90);
		resources.Add(new ResourceSpec(quantity, categoryId, identifier)); 
		while (la.kind == 31) {
			Get();
			ResourceExp(out List<ResourceSpec> continuation );
			resources.AddRange(continuation);
		}
	}

	void Recurrence(out RecurrenceSpec recurrence) {
		Expect(66);
		RecurrenceMode mode = RecurrenceMode.STRICT; Exp? endMarker = null; 
		if (la.kind == 67) {
			Get();
			mode = RecurrenceMode.STRICT; 
		} else if (la.kind == 68) {
			Get();
			mode = RecurrenceMode.FLEXIBLE; 
		} else SynErr(91);
		Expect(69);
		Exp(out Exp everyDuration);
		if (la.kind == 70) {
			Get();
			AdditiveExp(out Exp toDatetime);
			endMarker = toDatetime; 
		} else if (la.kind == 53) {
			Get();
			AdditiveExp(out Exp forDuration);
			endMarker = forDuration; 
		} else SynErr(92);
		recurrence = new RecurrenceSpec(mode, everyDuration, endMarker); 
	}



	public void Parse() {
		la = new Token();
		la.val = "";		
		Get();
		RAL();
		Expect(0);

	}
	
