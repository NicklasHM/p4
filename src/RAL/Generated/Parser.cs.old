public class Errors {
	public int count = 0;                                    // number of errors detected
	public System.IO.TextWriter errorStream = Console.Out;   // error messages go to this stream
	public string errMsgFormat = "-- line {0} col {1}: {2}"; // 0=line, 1=column, 2=text

	public virtual void SynErr (int line, int col, int n) {
		string s;
		switch (n) {
			case 0: s = "EOF expected"; break;
			case 1: s = "ident expected"; break;
			case 2: s = "number expected"; break;
			case 3: s = "stringLit expected"; break;
			case 4: s = "dateLit expected"; break;
			case 5: s = "timeLit expected"; break;
			case 6: s = "\";\" expected"; break;
			case 7: s = "\"move\" expected"; break;
			case 8: s = "\"to\" expected"; break;
			case 9: s = "\"cancel\" expected"; break;
			case 10: s = "\"if\" expected"; break;
			case 11: s = "\"(\" expected"; break;
			case 12: s = "\")\" expected"; break;
			case 13: s = "\"then\" expected"; break;
			case 14: s = "\"{\" expected"; break;
			case 15: s = "\"}\" expected"; break;
			case 16: s = "\"else\" expected"; break;
			case 17: s = "\"=\" expected"; break;
			case 18: s = "\"Number\" expected"; break;
			case 19: s = "\"Bool\" expected"; break;
			case 20: s = "\"String\" expected"; break;
			case 21: s = "\"Category\" expected"; break;
			case 22: s = "\"Reservation\" expected"; break;
			case 23: s = "\"DateTime\" expected"; break;
			case 24: s = "\"Duration\" expected"; break;
			case 25: s = "\"category\" expected"; break;
			case 26: s = "\"is\" expected"; break;
			case 27: s = "\"a\" expected"; break;
			case 28: s = "\"template\" expected"; break;
			case 29: s = "\",\" expected"; break;
			case 30: s = "\"or\" expected"; break;
			case 31: s = "\"and\" expected"; break;
			case 32: s = "\"seq\" expected"; break;
			case 33: s = "\"==\" expected"; break;
			case 34: s = "\"!=\" expected"; break;
			case 35: s = "\"<\" expected"; break;
			case 36: s = "\">\" expected"; break;
			case 37: s = "\"<=\" expected"; break;
			case 38: s = "\">=\" expected"; break;
			case 39: s = "\"+\" expected"; break;
			case 40: s = "\"-\" expected"; break;
			case 41: s = "\"*\" expected"; break;
			case 42: s = "\"/\" expected"; break;
			case 43: s = "\"not\" expected"; break;
			case 44: s = "\"true\" expected"; break;
			case 45: s = "\"false\" expected"; break;
			case 46: s = "\"reschedule\" expected"; break;
			case 47: s = "\"use\" expected"; break;
			case 48: s = "\".\" expected"; break;
			case 49: s = "\"check\" expected"; break;
			case 50: s = "\"reserve\" expected"; break;
			case 51: s = "\"where\" expected"; break;
			case 52: s = "\"from\" expected"; break;
			case 53: s = "\"for\" expected"; break;
			case 54: s = "\"w\" expected"; break;
			case 55: s = "\"week\" expected"; break;
			case 56: s = "\"weeks\" expected"; break;
			case 57: s = "\"d\" expected"; break;
			case 58: s = "\"day\" expected"; break;
			case 59: s = "\"days\" expected"; break;
			case 60: s = "\"h\" expected"; break;
			case 61: s = "\"hour\" expected"; break;
			case 62: s = "\"hours\" expected"; break;
			case 63: s = "\"m\" expected"; break;
			case 64: s = "\"minute\" expected"; break;
			case 65: s = "\"minutes\" expected"; break;
			case 66: s = "\"recurring\" expected"; break;
			case 67: s = "\"strict\" expected"; break;
			case 68: s = "\"flexible\" expected"; break;
			case 69: s = "\"every\" expected"; break;
			case 70: s = "\"until\" expected"; break;
			case 71: s = "??? expected"; break;
			case 72: s = "invalid TopLevelStmt"; break;
			case 73: s = "invalid Stmt"; break;
			case 74: s = "invalid Type"; break;
			case 75: s = "invalid ParamType"; break;
			case 76: s = "invalid UnaryExp"; break;
			case 77: s = "invalid Primary"; break;
			case 78: s = "invalid Duration"; break;
			case 79: s = "invalid Duration"; break;
			case 80: s = "invalid Duration"; break;
			case 81: s = "invalid Duration"; break;
			case 82: s = "invalid Duration"; break;
			case 83: s = "invalid Duration"; break;
			case 84: s = "invalid Duration"; break;
			case 85: s = "invalid Duration"; break;
			case 86: s = "invalid Duration"; break;
			case 87: s = "invalid Duration"; break;
			case 88: s = "invalid Duration"; break;
			case 89: s = "invalid Time"; break;
			case 90: s = "invalid ResourceExp"; break;
			case 91: s = "invalid Recurrence"; break;
			case 92: s = "invalid Recurrence"; break;

			default: s = "error " + n; break;
		}
		errorStream.WriteLine(errMsgFormat, line, col, s);
		count++;
	}

	public virtual void SemErr (int line, int col, string s) {
		errorStream.WriteLine(errMsgFormat, line, col, s);
		count++;
	}
	
	public virtual void SemErr (string s) {
		errorStream.WriteLine(s);
		count++;
	}
	
	public virtual void Warning (int line, int col, string s) {
		errorStream.WriteLine(errMsgFormat, line, col, s);
	}
	
	public virtual void Warning(string s) {
		errorStream.WriteLine(s);
	}
} // Errors


public class FatalError: Exception {
	public FatalError(string m): base(m) {}
}
